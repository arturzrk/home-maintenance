#!/usr/bin/env python
"""Polaris pre-commit encoding check.

Blocks em dashes, smart quotes, and other problematic Unicode characters
in staged markdown files.
"""
import os
import subprocess
import sys

BLOCKED = {
    "\u2014": ("em dash", "-"),
    "\u2015": ("horizontal bar", "-"),
    "\u2018": ("left single quote", "'"),
    "\u2019": ("right single quote", "'"),
    "\u201c": ("left double quote", '"'),
    "\u201d": ("right double quote", '"'),
    "\u2212": ("minus sign", "-"),
    "\u00b1": ("plus-minus", "+/-"),
    "\u00d7": ("multiplication sign", "x"),
    "\u00b0": ("degree sign", " degrees"),
    "\u00a0": ("non-breaking space", " "),
}


def main():
    # Get staged markdown files only
    try:
        result = subprocess.run(
            ["git", "diff", "--cached", "--name-only", "--diff-filter=ACM"],
            capture_output=True, text=True, check=True,
        )
    except (subprocess.CalledProcessError, FileNotFoundError):
        return 0

    staged_files = [f for f in result.stdout.strip().split("\n") if f.endswith(".md")]
    if not staged_files:
        return 0

    # Skip Polaris-generated agent command files - these are machine-generated
    # and should not block user commits if Polaris introduced a character.
    agent_cmd_prefixes = (
        ".claude/commands/", ".codex/prompts/", ".gemini/commands/",
        ".cursor/commands/", ".qwen/commands/", ".opencode/command/",
        ".windsurf/workflows/", ".kilocode/workflows/", ".augment/commands/",
        ".roo/commands/", ".amazonq/prompts/", ".github/prompts/",
    )
    staged_files = [f for f in staged_files if not f.startswith(agent_cmd_prefixes)]
    if not staged_files:
        return 0

    issues = []
    for fpath in staged_files:
        if not os.path.isfile(fpath):
            continue
        try:
            with open(fpath, "r", encoding="utf-8") as f:
                lines = f.readlines()
        except UnicodeDecodeError:
            issues.append(f"  {fpath}: invalid UTF-8 encoding")
            continue
        for lineno, line in enumerate(lines, 1):
            for char, (name, repl) in BLOCKED.items():
                if char in line:
                    col = line.index(char) + 1
                    issues.append(f"  {fpath}:{lineno}:{col} {name} -> '{repl}'")

    if issues:
        print("\nBlocked characters found in staged markdown files:\n")
        for i in issues[:20]:
            print(i)
        if len(issues) > 20:
            print(f"  ... and {len(issues) - 20} more")
        print("\nTo fix: polaris validate-encoding --all --fix")
        print("To bypass: git commit --no-verify\n")
        return 1

    return 0


if __name__ == "__main__":
    sys.exit(main())
