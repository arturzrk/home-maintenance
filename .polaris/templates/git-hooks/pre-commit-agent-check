#!/usr/bin/env python
"""Polaris pre-commit agent check: prevent committing agent directories.

Agent directories (.claude/, .codex/, etc.) may contain:
- Authentication tokens and API keys
- User-specific credentials (auth.json)
- Session data and conversation history

These should NEVER be committed to version control.
"""
import subprocess
import sys

AGENT_PATTERNS = [
    ".claude/", ".codex/", ".gemini/", ".cursor/", ".qwen/", ".opencode/",
    ".windsurf/", ".kilocode/", ".augment/", ".roo/", ".amazonq/",
    ".github/copilot/",
]

# Paths that are safe to commit (team-shared slash commands and skills)
ALLOWED_PATTERNS = [
    # Commands (slash commands shared across the team)
    ".claude/commands/",
    ".codex/prompts/",
    ".gemini/commands/",
    ".cursor/commands/",
    ".qwen/commands/",
    ".opencode/command/",
    ".windsurf/workflows/",
    ".kilocode/workflows/",
    ".augment/commands/",
    ".roo/commands/",
    ".amazonq/prompts/",
    ".github/prompts/",
    # Skills
    ".claude/skills/",
    # CLAUDE.md and agent config files (team-shared instructions)
    "CLAUDE.md",
    ".claude/CLAUDE.md",
]


def main():
    try:
        result = subprocess.run(
            ["git", "diff", "--cached", "--name-only", "--diff-filter=ACM"],
            capture_output=True, text=True, check=True,
        )
    except (subprocess.CalledProcessError, FileNotFoundError):
        return 0

    staged_files = [f for f in result.stdout.strip().split("\n") if f]
    if not staged_files:
        return 0

    blocked = []
    for f in staged_files:
        is_agent = any(f.startswith(p) for p in AGENT_PATTERNS)
        is_allowed = any(f.startswith(p) for p in ALLOWED_PATTERNS)
        if is_agent and not is_allowed:
            blocked.append(f)

    if blocked:
        print("COMMIT BLOCKED: Agent runtime/auth files detected")
        print()
        print("The following files may contain credentials or session data:")
        for f in blocked:
            print(f"  {f}")
        print()
        print("Safe to commit (team-shared): commands/, prompts/, skills/, CLAUDE.md")
        print("Never commit: settings.local.json, auth.json, conversation history")
        print()
        print("To fix:")
        print("  1. Unstage these files: git reset HEAD <file>")
        print("  2. Run: polaris upgrade  (updates .gitignore rules)")
        print()
        print("To bypass: git commit --no-verify")
        return 1

    return 0


if __name__ == "__main__":
    sys.exit(main())
