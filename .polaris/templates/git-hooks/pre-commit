#!/usr/bin/env python
"""Polaris pre-commit hook: orchestrates all pre-commit checks.

This hook runs all individual check scripts in the git-hooks directory.
Individual checks can be bypassed with --no-verify, but this should be
used sparingly and only when you're certain the commit is safe.
"""
import os
import subprocess
import sys
from pathlib import Path


def main():
    hooks_dir = Path(__file__).resolve().parent

    checks = ["pre-commit-encoding-check", "pre-commit-agent-check", "pre-commit-branch-guard"]

    for check_name in checks:
        check_path = hooks_dir / check_name
        if check_path.exists():
            result = subprocess.run(
                [sys.executable, str(check_path)],
                cwd=os.getcwd(),
            )
            if result.returncode != 0:
                return 1

    return 0


if __name__ == "__main__":
    sys.exit(main())
