## NextAuth core (required)
##   Generate the secret with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

## Google OIDC (used in production)
##   Create an OAuth 2.0 Client (Web app) at
##   https://console.cloud.google.com/apis/credentials and set the
##   authorized redirect URI to:
##     {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

## Dev stub (Development convenience, NEVER enable in production)
## When true, /signin shows a credentials form that mints an idToken of
## shape \"dev-<sub>\" matching the backend's DevStubAuthenticationHandler.
NEXTAUTH_DEV_STUB=true

## Backend API base URL (server-side only; not exposed to the browser)
API_BASE_URL=http://localhost:5000

## Backend public URL (exposed to the browser via NEXT_PUBLIC_*)
NEXT_PUBLIC_API_URL=http://localhost:5000
