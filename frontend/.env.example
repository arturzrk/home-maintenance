## Local development template.
## Copy to .env.local (gitignored) and fill in.
## For staging / production, set the same variables in the deployment
## platform (Vercel project settings, Render, etc.) - never commit
## real secrets to the repo.

## NextAuth core (required everywhere)
##   Generate the secret per environment:
##     openssl rand -base64 32
##   Each environment MUST have its own NEXTAUTH_SECRET. Reusing a dev
##   secret in staging defeats the cookie signing.
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

## Google OIDC (required in staging / production; ignored when
## NEXTAUTH_DEV_STUB=true).
##
##   Create one OAuth 2.0 Client per environment in the
##   Google Cloud Console: https://console.cloud.google.com/apis/credentials
##   Application type: Web application.
##   Authorized redirect URI:  {NEXTAUTH_URL}/api/auth/callback/google
##
##   See docs/oidc-setup.md for the full GCP walkthrough and the
##   backend audience/issuer wiring.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

## Dev stub (Development convenience, MUST be unset/false outside dev).
## When true, /signin shows a credentials form that mints an idToken of
## shape "dev-<sub>" matching the backend's DevStubAuthenticationHandler.
NEXTAUTH_DEV_STUB=true

## Backend API base URL (server-side only; not exposed to the browser).
##   Local:   http://localhost:5000
##   Staging: https://staging-api.maintained.house  (example)
API_BASE_URL=http://localhost:5000

## Backend public URL (exposed to the browser via NEXT_PUBLIC_*).
## Used for the /health and / probes in the dashboard. Safe to expose;
## same value as API_BASE_URL in most setups.
NEXT_PUBLIC_API_URL=http://localhost:5000
